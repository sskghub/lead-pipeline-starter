# Copy to .env for local experiments only. Production uses Modal secrets.
# Never commit .env.

# Reoon (or swap for another verifier — see README)
REOON_API_KEY=your_reoon_api_key_here

# Google Sheet ID from the sheet URL
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Full service account JSON as a single line (Modal secret uses the same)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Required for HTTP trigger. Same value must be in Modal secret PIPELINE_AUTH_TOKEN.
# Generate a long random string (e.g. openssl rand -hex 32)
PIPELINE_AUTH_TOKEN=your_long_random_secret_here
